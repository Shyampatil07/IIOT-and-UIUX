import random
def fitness(x):
  return x**2
# ◆ Step 1: Initialization
population = [random.randint(1, 10) for _ in range(5)]
for generation in range(5):
  print(f"\nGeneration {generation+1}:", population)
# ◆ Step 2: Fitness Evaluation
population = sorted(population, key=fitness, reverse=True)
# ◆ Step 3: Selection (best individuals)
best = population[:2]
# ◆ Step 4: Cloning
clones = []
for b in best:
  for _ in range(3):
# ◆ Step 5: Mutation
   mutated = b + random.randint(-1, 1)
clones.append(mutated)
# ◆ Step 6: Selection from combined population
combined = population + clones
population = sorted(combined, key=fitness, reverse=True)[:5]
# Final best
best_solution = max(population, key=fitness)
print("\nBest solution:", best_solution)


