Simple Artificial Immune Pattern Recognition for Damage Classification
import random

# ---------------------------------
# Training Data
# ---------------------------------

# Vibration values
# < 30  -> Healthy
# 30-60 -> Damaged
# > 60  -> Severe Damage

training_data = [
    (10, "Healthy"),
    (20, "Healthy"),
    (35, "Damaged"),
    (45, "Damaged"),
    (70, "Severe Damage"),
    (80, "Severe Damage")
]

print("Training Data:")
print(training_data)

# ---------------------------------
# Generate Antibodies
# ---------------------------------

antibodies = []

for i in range(5):

    antibodies.append(
        random.randint(0, 100)
    )

print("\nInitial Antibodies:")
print(antibodies)

# ---------------------------------
# Affinity Function
# ---------------------------------

def affinity(antibody, antigen):

    # Smaller difference = higher affinity
    return 1 / (1 + abs(antibody - antigen))

# ---------------------------------
# Classification Function
# ---------------------------------

def classify(value):

    best_antibody = None
    best_affinity = -1

    # Find best antibody
    for antibody in antibodies:

        aff = affinity(antibody, value)

        if aff > best_affinity:

            best_affinity = aff
            best_antibody = antibody

    # Classification Rules
    if value < 30:
        category = "Healthy"

    elif value <= 60:
        category = "Damaged"

    else:
        category = "Severe Damage"

    return best_antibody, category

# ---------------------------------
# Test Data
# ---------------------------------

test_values = [15, 40, 75]

print("\nDamage Classification:\n")

for value in test_values:

    antibody, result = classify(value)

    print(
        f"Input Vibration = {value}"
    )

    print(
        f"Matched Antibody = {antibody}"
    )

    print(
        f"Structure Status = {result}\n"
    )
