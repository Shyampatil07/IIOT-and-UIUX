import random

from deap import base
from deap import creator
from deap import tools
from deap import algorithms

# ---------------------------------
# Create Fitness Function
# ---------------------------------

creator.create(
    "FitnessMax",
    base.Fitness,
    weights=(1.0,)
)

# ---------------------------------
# Create Individual
# ---------------------------------

creator.create(
    "Individual",
    list,
    fitness=creator.FitnessMax
)

toolbox = base.Toolbox()

# ---------------------------------
# Attribute Generator
# ---------------------------------

toolbox.register(
    "attr_int",
    random.randint,
    0,
    10
)

# ---------------------------------
# Structure Initializers
# ---------------------------------

toolbox.register(
    "individual",
    tools.initRepeat,
    creator.Individual,
    toolbox.attr_int,
    n=5
)

toolbox.register(
    "population",
    tools.initRepeat,
    list,
    toolbox.individual
)

# ---------------------------------
# Fitness Function
# ---------------------------------

def evalFunction(individual):

    x = individual[0]

    return (x * x,)

toolbox.register(
    "evaluate",
    evalFunction
)

# ---------------------------------
# Genetic Operators
# ---------------------------------

toolbox.register(
    "mate",
    tools.cxTwoPoint
)

toolbox.register(
    "mutate",
    tools.mutFlipBit,
    indpb=0.1
)

toolbox.register(
    "select",
    tools.selTournament,
    tournsize=3
)

# ---------------------------------
# Main Program
# ---------------------------------

population = toolbox.population(n=6)

NGEN = 5

for gen in range(NGEN):

    print(f"\nGeneration {gen + 1}")

    # Evaluate fitness
    fitnesses = list(
        map(toolbox.evaluate, population)
    )

    for ind, fit in zip(population, fitnesses):

        ind.fitness.values = fit

    # Print individuals
    for ind in population:

        print(
            f"Individual: {ind} "
            f"Fitness: {ind.fitness.values}"
        )

    # Selection
    offspring = toolbox.select(
        population,
        len(population)
    )

    offspring = list(map(toolbox.clone, offspring))

    # Crossover
    for child1, child2 in zip(
        offspring[::2],
        offspring[1::2]
    ):

        if random.random() < 0.7:

            toolbox.mate(child1, child2)

            del child1.fitness.values
            del child2.fitness.values

    # Mutation
    for mutant in offspring:

        if random.random() < 0.2:

            toolbox.mutate(mutant)

            del mutant.fitness.values

    population[:] = offspring

# ---------------------------------
# Best Solution
# ---------------------------------

best = tools.selBest(population, 1)[0]

print("\nBest Individual:", best)

print(
    "Best Fitness:",
    evalFunction(best)
)
