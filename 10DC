Python Program using XML-RPC
1. Server Program
server.py
from xmlrpc.server import SimpleXMLRPCServer

# -----------------------------------
# Booking Database
# -----------------------------------

bookings = {}

room_number = 101

# -----------------------------------
# Book Room Function
# -----------------------------------

def book_room(guest_name):

    global room_number

    if guest_name in bookings:

        return (
            "Guest already has booking."
        )

    bookings[guest_name] = room_number

    message = (
        f"Room booked successfully\n"
        f"Guest Name : {guest_name}\n"
        f"Room Number : {room_number}"
    )

    room_number += 1

    return message

# -----------------------------------
# Cancel Booking Function
# -----------------------------------

def cancel_booking(guest_name):

    if guest_name in bookings:

        del bookings[guest_name]

        return (
            f"Booking cancelled for "
            f"{guest_name}"
        )

    return "Guest booking not found."

# -----------------------------------
# Create Server
# -----------------------------------

server = SimpleXMLRPCServer(
    ("127.0.0.1", 8000)
)

print(
    "Hotel Booking Server Running..."
)

# Register functions
server.register_function(
    book_room,
    "book_room"
)

server.register_function(
    cancel_booking,
    "cancel_booking"
)

# Start server
server.serve_forever()
2. Client Program
client.py
import xmlrpc.client

# Connect to server
proxy = xmlrpc.client.ServerProxy(
    "http://127.0.0.1:8000/"
)

while True:

    print("\n1. Book Room")

    print("2. Cancel Booking")

    print("3. Exit")

    choice = int(input(
        "Enter Choice : "
    ))

    # -----------------------------
    # Book Room
    # -----------------------------

    if choice == 1:

        guest = input(
            "Enter Guest Name : "
        )

        result = proxy.book_room(guest)

        print("\n", result)

    # -----------------------------
    # Cancel Booking
    # -----------------------------

    elif choice == 2:

        guest = input(
            "Enter Guest Name : "
        )

        result = proxy.cancel_booking(
            guest
        )

        print("\n", result)

    # -----------------------------
    # Exit
    # -----------------------------

    elif choice == 3:

        print("Exiting...")

        break

    else:

        print("Invalid Choice")
