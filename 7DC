import random
import math
# ◆ Sample dataset (features: vibration, crack_length)
# label: 0 = Undamaged, 1 = Damaged
data = [
([0.1, 0.2], 0),
([0.2, 0.1], 0),
([0.8, 0.9], 1),
([0.7, 0.8], 1),
([0.15, 0.25], 0),
([0.85, 0.95], 1)
]
# ◆ Distance function (Euclidean)
def distance(a, b):
return math.sqrt(sum((x - y) ** 2 for x, y in zip(a, b)))
# ◆ Step 1: Initialize antibodies (memory cells)
antibodies = []
for _ in range(4):
features, label = random.choice(data)
antibodies.append((features, label))
# ◆ Training (Clonal Selection inspired)
for iteration in range(5):
new_antibodies = []
for ab_features, ab_label in antibodies:
# clone and mutate
for _ in range(2):
mutated = [x + random.uniform(-0.1, 0.1) for x in ab_features]
new_antibodies.append((mutated, ab_label))
# combine old + new
antibodies.extend(new_antibodies)
# select best antibodies (closest to training data)
antibodies = sorted(
antibodies,
key=lambda ab: sum(distance(ab[0], d[0]) for d in data)
)[:6]
# ◆ Classification function
def classify(sample):
nearest = min(antibodies, key=lambda ab: distance(sample, ab[0]))
return nearest[1]
# ◆ Testing + Evaluation
TP = TN = FP = FN = 0
print("\n--- Classification Results ---")
for features, actual in data:
pred = classify(features)
print(f"Input: {features} -> Predicted: {pred}, Actual: {actual}")
if pred == 1 and actual == 1:
TP += 1
elif pred == 0 and actual == 0:
TN += 1
elif pred == 1 and actual == 0:
FP += 1
elif pred == 0 and actual == 1:
FN += 1
# ◆ Metrics
accuracy = (TP + TN) / len(data)
sensitivity = TP / (TP + FN) if (TP + FN) != 0 else 0
specificity = TN / (TN + FP) if (TN + FP) != 0 else 0
print("\n--- Performance ---")
print("Accuracy:", round(accuracy, 2))
print("Sensitivity:", round(sensitivity, 2))
print("Specificity:", round(specificity, 2))

